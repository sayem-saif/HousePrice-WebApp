d-cols-2 gap-8\" data-kid=\"215\">\n              <div class=\"aspect-square bg-slate-800/50 border border-slate-700 rounded-[2.5rem] flex flex-col items-center justify-center p-6 text-center shadow-xl\" data-kid=\"216\">\n                 <p class=\"text-slate-500 text-[10px] font-black uppercase tracking-[0.2em] mb-4\" data-kid=\"217\">Data Points</p>\n                 <p class=\"text-4xl lg:text-5xl font-black text-white font-heading mb-2\" data-kid=\"218\">50+</p>\n                 <p class=\"text-slate-400 text-xs\" data-kid=\"219\">per valuation</p>\n              </div>\n              <div class=\"aspect-square bg-yellow-400 rounded-[2.5rem] flex flex-col items-center justify-center p-6 text-center shadow-2xl shadow-yellow-400/20\" data-kid=\"220\">\n                 <p class=\"text-slate-950 font-black text-xs uppercase tracking-[0.2em] mb-4\" data-kid=\"221\">Cost</p>\n                 <p class=\"text-5xl font-black text-slate-950 font-heading mb-2\" data-kid=\"222\">$0</p>\n                 <p class=\"text-slate-900 font-bold\" data-kid=\"223\">Free Forever</p>\n              </div>\n              <div class=\"aspect-square bg-slate-950 border border-slate-800 rounded-[2.5rem] flex flex-col items-center justify-center p-6 text-center shadow-xl\" data-kid=\"224\">\n                 <div class=\"w-12 h-12 bg-slate-900 border border-slate-800 rounded-full flex items-center justify-center mb-4\" data-kid=\"225\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#facc15\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"226\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\" data-kid=\"227\"></path></svg>\n                 </div>\n                 <p class=\"text-white font-bold mb-1\" data-kid=\"228\">Secure</p>\n                 <p class=\"text-slate-500 text-[10px] leading-relaxed\" data-kid=\"229\">Anonymous analysis without registration.</p>\n              </div>\n              <div class=\"aspect-square bg-slate-800/20 border border-slate-800/50 rounded-[2.5rem] flex flex-col items-center justify-center p-6 text-center shadow-xl overflow-hidden relative\" data-kid=\"230\">\n                 <div class=\"absolute inset-0 flex items-center justify-center opacity-10\" data-kid=\"231\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"120\" height=\"120\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"1\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"232\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\" data-kid=\"233\"></path><circle cx=\"12\" cy=\"10\" r=\"3\" data-kid=\"234\"></circle></svg>\n                 </div>\n                 <p class=\"text-slate-300 font-medium\" data-kid=\"235\">Hyper-local coverage across all US states.</p>\n              </div>\n            </div>\n            \n            <div class=\"absolute -bottom-8 -left-8 bg-slate-950 border border-slate-800 p-4 rounded-2xl flex items-center gap-3 shadow-2xl\" data-kid=\"236\">\n              <div class=\"w-2 h-2 rounded-full bg-green-400 animate-pulse\" data-kid=\"237\"></div>\n              <span class=\"text-xs font-bold text-white uppercase tracking-wider\" data-kid=\"238\">Live Model: v4.2.0</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 border-t border-slate-800/50 bg-slate-950/30\" data-kid=\"239\">\n      <div class=\"max-w-4xl mx-auto\" data-kid=\"240\">\n        <div class=\"text-center mb-20\" data-kid=\"241\">\n          <h2 class=\"text-yellow-400 text-xs font-black uppercase tracking-[0.3em] mb-4\" data-kid=\"242\">Common Questions</h2>\n          <h3 class=\"text-4xl font-extrabold font-heading text-white\" data-kid=\"243\">Everything you need to know.</h3>\n        </div>\n\n        <div class=\"space-y-4\" data-kid=\"244\">\n          \n          <details class=\"group bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden\" data-kid=\"245\">\n            <summary class=\"flex items-center justify-between p-6 cursor-pointer list-none\" data-kid=\"246\">\n              <span class=\"text-lg font-bold text-white group-hover:text-yellow-400 transition-colors\" data-kid=\"247\">How accurate are the house price predictions?</span>\n              <span class=\"transition-transform group-open:rotate-180\" data-kid=\"248\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"249\"><path d=\"m6 9 6 6 6-6\" data-kid=\"250\"></path></svg>\n              </span>\n            </summary>\n            <div class=\"px-6 pb-6 text-slate-400 leading-relaxed\" data-kid=\"251\">\n              Our AI models typically fall within 5-10% of actual market values. While accuracy varies by location, we provide confidence intervals for every estimate to help you understand the reliability of the data.\n            </div>\n          </details>\n          \n          <details class=\"group bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden\" data-kid=\"252\">\n            <summary class=\"flex items-center justify-between p-6 cursor-pointer list-none\" data-kid=\"253\">\n              <span class=\"text-lg font-bold text-white group-hover:text-yellow-400 transition-colors\" data-kid=\"254\">Is the house price predictor really free to use?</span>\n              <span class=\"transition-transform group-open:rotate-180\" data-kid=\"255\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"256\"><path d=\"m6 9 6 6 6-6\" data-kid=\"257\"></path></svg>\n              </span>\n            </summary>\n            <div class=\"px-6 pb-6 text-slate-400 leading-relaxed\" data-kid=\"258\">\n              Absolutely. Our tool is 100% free with no hidden fees, registration requirements, or usage limits. We believe market intelligence should be accessible to everyone.\n            </div>\n          </details>\n          \n          <details class=\"group bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden\" data-kid=\"259\">\n            <summary class=\"flex items-center justify-between p-6 cursor-pointer list-none\" data-kid=\"260\">\n              <span class=\"text-lg font-bold text-white group-hover:text-yellow-400 transition-colors\" data-kid=\"261\">What information do I need to get a prediction?</span>\n              <span class=\"transition-transform group-open:rotate-180\" data-kid=\"262\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"263\"><path d=\"m6 9 6 6 6-6\" data-kid=\"264\"></path></svg>\n              </span>\n            </summary>\n            <div class=\"px-6 pb-6 text-slate-400 leading-relaxed\" data-kid=\"265\">\n              Basic details include number of bedrooms/bathrooms, living area square footage, lot size, floors, condition, year built, and city. Optional features like waterfront access or renovations can improve accuracy.\n            </div>\n          </details>\n          \n          <details class=\"group bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden\" data-kid=\"266\">\n            <summary class=\"flex items-center justify-between p-6 cursor-pointer list-none\" data-kid=\"267\">\n              <span class=\"text-lg font-bold text-white group-hover:text-yellow-400 transition-colors\" data-kid=\"268\">Can I use this for commercial properties?</span>\n              <span class=\"transition-transform group-open:rotate-180\" data-kid=\"269\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"270\"><path d=\"m6 9 6 6 6-6\" data-kid=\"271\"></path></svg>\n              </span>\n            </summary>\n            <div class=\"px-6 pb-6 text-slate-400 leading-relaxed\" data-kid=\"272\">\n              Our model is optimized for residential single-family homes, condos, and townhouses. While you can enter commercial data, the predictions may be less accurate as the training set is primarily residential.\n            </div>\n          </details>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-24 px-6\" data-kid=\"273\">\n      <div class=\"max-w-7xl mx-auto\" data-kid=\"274\">\n        <div class=\"relative bg-slate-950 border border-slate-800 rounded-[3rem] p-12 lg:p-24 overflow-hidden shadow-2xl\" data-kid=\"275\">\n          \n          <div class=\"absolute top-0 right-0 w-96 h-96 bg-yellow-400/5 blur-[100px] rounded-full -mr-48 -mt-48\" data-kid=\"276\"></div>\n          <div class=\"absolute bottom-0 left-0 w-96 h-96 bg-blue-500/5 blur-[100px] rounded-full -ml-48 -mb-48\" data-kid=\"277\"></div>\n          \n          <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 32px 32px;\" data-kid=\"278\"></div>\n          \n          <div class=\"relative z-10 text-center max-w-3xl mx-auto\" data-kid=\"279\">\n            <h2 class=\"text-4xl lg:text-6xl font-extrabold font-heading text-white mb-8 leading-tight\" data-kid=\"280\">Ready to discover your property's value?</h2>\n            <p class=\"text-xl text-slate-400 mb-12\" data-kid=\"281\">Join over 12 million users who have used our AI-powered desk for instant real estate valuations.</p>\n            <div class=\"flex flex-col sm:flex-row justify-center gap-6\" data-kid=\"282\">\n              <button class=\"accent-button px-10 py-5 rounded-2xl font-black text-xl shadow-xl shadow-yellow-400/10\" data-kid=\"283\">Start Your Free Prediction</button>\n              <button class=\"bg-slate-950 text-white border border-slate-700 px-10 py-5 rounded-2xl font-black text-xl hover:bg-slate-900 transition-all\" data-kid=\"284\">Talk to an Agent</button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  \n  <footer class=\"bg-slate-950 pt-24 pb-12 px-6 border-t border-slate-800/50\" data-kid=\"285\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"286\">\n      <div class=\"grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-12 mb-20\" data-kid=\"287\">\n        <div class=\"col-span-2\" data-kid=\"288\">\n          <div class=\"flex items-center gap-2 mb-8\" data-kid=\"289\">\n            <div class=\"w-8 h-8 bg-yellow-400 rounded-lg flex items-center justify-center\" data-kid=\"290\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#0f172a\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"291\"><path d=\"m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\" data-kid=\"292\"></path><polyline points=\"9 22 9 12 15 12 15 22\" data-kid=\"293\"></polyline></svg>\n            </div>\n            <span class=\"text-xl font-black font-heading tracking-tight text-white\" data-kid=\"294\">Appraisal<span class=\"text-yellow-400\" data-kid=\"295\">Desk</span></span>\n          </div>\n          <p class=\"text-slate-500 text-sm leading-relaxed max-w-xs mb-8\" data-kid=\"296\">Providing AI-powered real estate price estimation and market analysis for the modern homeowner.</p>\n          <div class=\"flex gap-4\" data-kid=\"297\">\n             <a href=\"#\" class=\"w-10 h-10 bg-slate-900 rounded-xl flex items-center justify-center text-slate-400 hover:text-yellow-400 transition-colors border border-slate-800\" data-kid=\"298\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"299\"><path d=\"M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z\" data-kid=\"300\"></path></svg>\n             </a>\n             <a href=\"#\" class=\"w-10 h-10 bg-slate-900 rounded-xl flex items-center justify-center text-slate-400 hover:text-yellow-400 transition-colors border border-slate-800\" data-kid=\"301\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"302\"><rect width=\"20\" height=\"20\" x=\"2\" y=\"2\" rx=\"5\" ry=\"5\" data-kid=\"303\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\" data-kid=\"304\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\" data-kid=\"305\"></line></svg>\n             </a>\n             <a href=\"#\" class=\"w-10 h-10 bg-slate-900 rounded-xl flex items-center justify-center text-slate-400 hover:text-yellow-400 transition-colors border border-slate-800\" data-kid=\"306\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"307\"><path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\" data-kid=\"308\"></path><rect width=\"4\" height=\"12\" x=\"2\" y=\"9\" data-kid=\"309\"></rect></svg>\n             </a>\n          </div>\n        </div>\n\n        <div data-kid=\"310\">\n          <h4 class=\"text-white font-bold mb-6\" data-kid=\"311\">Product</h4>\n          <ul class=\"space-y-4\" data-kid=\"312\">\n            <li data-kid=\"313\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"314\">House Predictor</a></li>\n            <li data-kid=\"315\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"316\">Market Signals</a></li>\n            <li data-kid=\"317\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"318\">Portfolio Tracker</a></li>\n            <li data-kid=\"319\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"320\">API Access</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"321\">\n          <h4 class=\"text-white font-bold mb-6\" data-kid=\"322\">Company</h4>\n          <ul class=\"space-y-4\" data-kid=\"323\">\n            <li data-kid=\"324\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"325\">About Us</a></li>\n            <li data-kid=\"326\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"327\">Careers</a></li>\n            <li data-kid=\"328\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"329\">Press Kit</a></li>\n            <li data-kid=\"330\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"331\">Contact</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"332\">\n          <h4 class=\"text-white font-bold mb-6\" data-kid=\"333\">Resources</h4>\n          <ul class=\"space-y-4\" data-kid=\"334\">\n            <li data-kid=\"335\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"336\">Market Reports</a></li>\n            <li data-kid=\"337\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"338\">Blog</a></li>\n            <li data-kid=\"339\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"340\">Help Center</a></li>\n            <li data-kid=\"341\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"342\">Community</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"343\">\n          <h4 class=\"text-white font-bold mb-6\" data-kid=\"344\">Legal</h4>\n          <ul class=\"space-y-4\" data-kid=\"345\">\n            <li data-kid=\"346\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"347\">Privacy Policy</a></li>\n            <li data-kid=\"348\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"349\">Terms of Service</a></li>\n            <li data-kid=\"350\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"351\">Cookie Policy</a></li>\n            <li data-kid=\"352\"><a href=\"#\" class=\"text-slate-500 hover:text-yellow-400 text-sm transition-colors\" data-kid=\"353\">Disclaimers</a></li>\n          </ul>\n        </div>\n      </div>\n\n      <div class=\"pt-12 border-t border-slate-900 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"354\">\n        <p class=\"text-slate-600 text-xs\" data-kid=\"355\">© 2024 Appraisal Desk AI. All rights reserved.</p>\n        <div class=\"flex items-center gap-2\" data-kid=\"356\">\n           <span class=\"text-slate-600 text-xs\" data-kid=\"357\">Powered by</span>\n           <span class=\"text-slate-400 text-xs font-black font-heading\" data-kid=\"358\">TurboAITools</span>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n",
