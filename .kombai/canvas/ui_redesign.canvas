      "html": "\n<div class=\"bg-slate-950 text-slate-200 font-sans selection:bg-amber-400 selection:text-slate-950\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');\n    \n    :root {\n      font-family: 'Plus Jakarta Sans', sans-serif;\n    }\n\n    .glass-card {\n      background-color: #0f172a; /* bg-slate-900 */\n      border: 1px solid #1e293b; /* border-slate-800 */\n    }\n\n    .accent-btn {\n      background-color: #fbbf24; /* bg-amber-400 */\n      color: #020617; /* text-slate-950 */\n      font-weight: 800;\n      transition: all 0.2s ease;\n    }\n\n    .accent-btn:hover {\n      background-color: #f59e0b; /* bg-amber-500 */\n      transform: translateY(-1px);\n    }\n\n    .secondary-btn {\n      background-color: transparent;\n      border: 1px solid #334155; /* border-slate-700 */\n      color: #94a3b8; /* text-slate-400 */\n      font-weight: 700;\n      transition: all 0.2s ease;\n    }\n\n    .secondary-btn:hover {\n      background-color: #1e293b; /* bg-slate-800 */\n      color: #f1f5f9; /* text-slate-100 */\n    }\n\n    .step-dot {\n      width: 40px;\n      height: 6px;\n      border-radius: 9999px;\n      background-color: #1e293b;\n    }\n\n    .step-dot.active {\n      background-color: #fbbf24;\n    }\n  </style>\n\n  \n  <header class=\"max-w-7xl mx-auto px-6 py-8 flex items-center justify-between\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n      <div class=\"w-11 h-11 bg-amber-400 rounded-xl flex items-center justify-center shadow-lg shadow-amber-400/10\" data-kid=\"4\">\n        <i data-lucide=\"calculator\" class=\"w-6 h-6 text-slate-950\" data-kid=\"5\"></i>\n      </div>\n      <span class=\"text-2xl font-black text-white tracking-tighter uppercase\" data-kid=\"6\">Turbo<span class=\"text-amber-400\" data-kid=\"7\">AI</span>Tools</span>\n    </div>\n    \n    <nav class=\"hidden md:flex items-center gap-10 text-sm font-black uppercase tracking-widest text-slate-500\" data-kid=\"8\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"9\">Products</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"10\">Solutions</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"11\">Resources</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"12\">About</a>\n    </nav>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"13\">\n      <button class=\"text-sm font-bold text-slate-400 hover:text-white transition-colors\" data-kid=\"14\">Sign In</button>\n      <button class=\"accent-btn px-6 py-2.5 rounded-lg text-sm shadow-lg shadow-amber-400/10\" data-kid=\"15\">Get Started</button>\n    </div>\n  </header>\n\n  \n  <section class=\"max-w-7xl mx-auto px-6 py-16 md:py-24 text-center\" data-kid=\"16\">\n    <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full border border-slate-800 bg-slate-900/50 text-amber-400 text-xs font-black uppercase tracking-widest mb-6\" data-kid=\"17\">\n      <i data-lucide=\"sparkles\" class=\"w-3.5 h-3.5\" data-kid=\"18\"></i>\n      Appraisal Desk Intelligence\n    </div>\n    <h1 class=\"text-4xl md:text-6xl lg:text-7xl font-black text-white mb-6 leading-tight max-w-5xl mx-auto\" data-kid=\"19\">\n      Free AI-Powered <span class=\"text-amber-400\" data-kid=\"20\">House Price Predictor</span>\n    </h1>\n    <p class=\"text-slate-400 text-lg md:text-xl mb-16 max-w-2xl mx-auto font-medium\" data-kid=\"21\">\n      An appraisal desk for instant house price prediction. Get a model-backed estimate in a focused workspace built for clarity.\n    </p>\n\n    \n    <div class=\"max-w-3xl mx-auto glass-card rounded-[2.5rem] p-8 md:p-14 text-left shadow-[0_32px_64px_-16px_rgba(0,0,0,0.5)]\" data-kid=\"22\">\n      <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12\" data-kid=\"23\">\n        <div data-kid=\"24\">\n          <span class=\"text-slate-500 text-xs font-black uppercase tracking-widest mb-1 block\" data-kid=\"25\">Step 1 of 13</span>\n          <h2 class=\"text-white text-2xl font-black\" data-kid=\"26\">Property Basics</h2>\n        </div>\n        <div class=\"flex gap-2\" data-kid=\"27\">\n          <div class=\"step-dot active\" data-kid=\"28\"></div>\n          <div class=\"step-dot\" data-kid=\"29\"></div>\n          <div class=\"step-dot\" data-kid=\"30\"></div>\n          <div class=\"step-dot\" data-kid=\"31\"></div>\n          <div class=\"step-dot\" data-kid=\"32\"></div>\n        </div>\n      </div>\n\n      <div class=\"mb-12\" data-kid=\"33\">\n        <label class=\"block text-slate-400 text-sm font-bold mb-4 uppercase tracking-wide\" data-kid=\"34\">How many bedrooms does the property have?</label>\n        <div class=\"relative group\" data-kid=\"35\">\n          <div class=\"absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none\" data-kid=\"36\">\n            <i data-lucide=\"bed\" class=\"w-6 h-6 text-slate-500 group-focus-within:text-amber-400 transition-colors\" data-kid=\"37\"></i>\n          </div>\n          <input type=\"number\" placeholder=\"Enter number of bedrooms\" class=\"w-full bg-slate-950 border-2 border-slate-800 rounded-2xl pl-16 pr-6 py-6 text-xl text-white font-bold focus:outline-hidden focus:border-amber-400 transition-all placeholder:text-slate-700\" data-kid=\"38\">\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6\" data-kid=\"39\">\n        <button class=\"secondary-btn py-6 rounded-2xl flex items-center justify-center gap-3 text-lg\" data-kid=\"40\">\n          <i data-lucide=\"arrow-left\" class=\"w-5 h-5\" data-kid=\"41\"></i>\n          Previous\n        </button>\n        <button class=\"accent-btn py-6 rounded-2xl flex items-center justify-center gap-3 text-lg shadow-xl shadow-amber-400/20\" data-kid=\"42\">\n          Next Step\