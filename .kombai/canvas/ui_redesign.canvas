mb-10 group-hover:scale-110 transition-transform relative z-10 ring-8 ring-slate-950\" data-kid=\"141\">2</div>\n        <h3 class=\"text-2xl font-black text-white mb-4\" data-kid=\"142\">AI Analysis</h3>\n        <p class=\"text-slate-400 leading-relaxed font-medium\" data-kid=\"143\">Our machine learning model analyzes your property against thousands of comparable sales in your city.</p>\n      </div>\n      \n      <div class=\"text-center group\" data-kid=\"144\">\n        <div class=\"w-24 h-24 bg-amber-400 text-slate-950 rounded-full flex items-center justify-center text-4xl font-black mx-auto mb-10 group-hover:scale-110 transition-transform relative z-10 ring-8 ring-slate-950\" data-kid=\"145\">3</div>\n        <h3 class=\"text-2xl font-black text-white mb-4\" data-kid=\"146\">Get Instant Predictions</h3>\n        <p class=\"text-slate-400 leading-relaxed font-medium\" data-kid=\"147\">Receive accurate price estimates with confidence intervals and detailed insights instantly.</p>\n      </div>\n    </div>\n\n    <div class=\"mt-20 bg-slate-900/50 border border-slate-800 rounded-3xl p-10 flex flex-col md:flex-row items-center gap-10\" data-kid=\"148\">\n      <div class=\"w-20 h-20 bg-amber-400/10 text-amber-400 border border-amber-400/20 rounded-2xl shrink-0 flex items-center justify-center shadow-inner\" data-kid=\"149\">\n        <i data-lucide=\"lightbulb\" class=\"w-10 h-10\" data-kid=\"150\"></i>\n      </div>\n      <div data-kid=\"151\">\n        <h4 class=\"text-2xl font-black text-white mb-3 uppercase tracking-wider\" data-kid=\"152\">Expert Insight</h4>\n        <p class=\"text-slate-400 leading-relaxed font-medium text-lg\" data-kid=\"153\">For the most accurate house price predictions, provide as much detail as possible. Our house price finder becomes significantly more precise with complete property information including renovation history.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"max-w-7xl mx-auto px-6 py-24\" data-kid=\"154\">\n    <div class=\"text-center mb-16\" data-kid=\"155\">\n      <h2 class=\"text-3xl md:text-5xl font-black text-white mb-4\" data-kid=\"156\">Who Can Benefit from Our <span class=\"text-amber-400\" data-kid=\"157\">Tool</span>?</h2>\n      <p class=\"text-slate-400 text-lg\" data-kid=\"158\">Tailored insights for every real estate professional and homeowner.</p>\n    </div>\n\n    <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\" data-kid=\"159\">\n      <div class=\"glass-card p-8 rounded-3xl group hover:bg-slate-900 transition-colors\" data-kid=\"160\">\n        <div class=\"text-amber-400 mb-6 group-hover:scale-110 transition-transform origin-left\" data-kid=\"161\">\n          <i data-lucide=\"shopping-bag\" class=\"w-10 h-10\" data-kid=\"162\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold text-white mb-3\" data-kid=\"163\">Home Buyers</h3>\n        <p class=\"text-slate-400 text-sm leading-relaxed\" data-kid=\"164\">Evaluate if a property is fairly priced and negotiate better deals with confidence in any market.</p>\n      </div>\n      \n      <div class=\"glass-card p-8 rounded-3xl group hover:bg-slate-900 transition-colors\" data-kid=\"165\">\n        <div class=\"text-amber-400 mb-6 group-hover:scale-110 transition-transform origin-left\" data-kid=\"166\">\n          <i data-lucide=\"tag\" class=\"w-10 h-10\" data-kid=\"167\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold text-white mb-3\" data-kid=\"168\">Home Sellers</h3>\n        <p class=\"text-slate-400 text-sm leading-relaxed\" data-kid=\"169\">Get accurate predictions before listing to set competitive prices that attract serious buyers.</p>\n      </div>\n      \n      <div class=\"glass-card p-8 rounded-3xl group hover:bg-slate-900 transition-colors\" data-kid=\"170\">\n        <div class=\"text-amber-400 mb-6 group-hover:scale-110 transition-transform origin-left\" data-kid=\"171\">\n          <i data-lucide=\"trending-up\" class=\"w-10 h-10\" data-kid=\"172\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold text-white mb-3\" data-kid=\"173\">Real Estate Investors</h3>\n        <p class=\"text-slate-400 text-sm leading-relaxed\" data-kid=\"174\">Analyze potential investments quickly and identify undervalued properties with AI-backed data.</p>\n      </div>\n\n      <div class=\"glass-card p-8 rounded-3xl group hover:bg-slate-900 transition-colors\" data-kid=\"175\">\n        <div class=\"text-amber-400 mb-6 group-hover:scale-110 transition-transform origin-left\" data-kid=\"176\">\n          <i data-lucide=\"landmark\" class=\"w-10 h-10\" data-kid=\"177\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold text-white mb-3\" data-kid=\"178\">Mortgage Lenders</h3>\n        <p class=\"text-slate-400 text-sm leading-relaxed\" data-kid=\"179\">Quick preliminary valuations for loan applications and efficient initial risk assessments.</p>\n      </div>\n\n      <div class=\"glass-card p-8 rounded-3xl group hover:bg-slate-900 transition-colors\" data-kid=\"180\">\n        <div class=\"text-amber-400 mb-6 group-hover:scale-110 transition-transform origin-left\" data-kid=\"181\">\n          <i data-lucide=\"users\" class=\"w-10 h-10\" data-kid=\"182\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold text-white mb-3\" data-kid=\"183\">Real Estate Agents</h3>\n        <p class=\"text-slate-400 text-sm leading-relaxed\" data-kid=\"184\">Provide instant predictions to clients and build trust with accurate, localized real-time market data.</p>\n      </div>\n\n      <div class=\"glass-card p-8 rounded-3xl group hover:bg-slate-900 transition-colors\" data-kid=\"185\">\n        <div class=\"text-amber-400 mb-6 group-hover:scale-110 transition-transform origin-left\" data-kid=\"186\">\n          <i data-lucide=\"search\" class=\"w-10 h-10\" data-kid=\"187\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold text-white mb-3\" data-kid=\"188\">Property Researchers</h3>\n        <p class=\"text-slate-400 text-sm leading-relaxed\" data-kid=\"189\">Study market trends and pricing patterns across different neighborhoods with granular datasets.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"max-w-4xl mx-auto px-6 py-24\" data-kid=\"190\">\n    <h2 class=\"text-3xl md:text-5xl font-black text-white mb-16 text-center\" data-kid=\"191\">Frequently Asked <span class=\"text-amber-400\" data-kid=\"192\">Questions</span></h2>\n    <div class=\"space-y-6\" data-kid=\"193\">\n      <div class=\"bg-slate-900 border border-slate-800 rounded-[2rem] p-10 cursor-pointer hover:border-amber-400 transition-colors group\" data-kid=\"194\">\n        <div class=\"flex items-center justify-between mb-6\" data-kid=\"195\">\n          <h3 class=\"text-xl font-black text-amber-400\" data-kid=\"196\">How accurate are your house price predictions?</h3>\n          <i data-lucide=\"minus\" class=\"w-6 h-6 text-amber-400\" data-kid=\"197\"></i>\n        </div>\n        <p class=\"text-slate-400 leading-relaxed font-medium text-lg\" data-kid=\"198\">\n          Our house price predictor uses advanced machine learning algorithms trained on extensive real estate data. While accuracy varies by location and property type, our predictions typically fall within 5-10% of actual market values. The tool provides confidence intervals to help you understand the reliability of each estimate.\n        </p>\n      </div>\n\n      <div class=\"bg-slate-900 border border-slate-800 rounded-[2rem] p-8 cursor-pointer hover:border-amber-400 transition-colors group\" data-kid=\"199\">\n        <div class=\"flex items-center justify-between\" data-kid=\"200\">\n          <h3 class=\"text-xl font-black text-white group-hover:text-amber-400 transition-colors\" data-kid=\"201\">Can I find house prices near me for my specific neighborhood?</h3>\n          <i data-lucide=\"plus\" class=\"w-6 h-6 text-slate-600 group-hover:text-amber-400 transition-colors\" data-kid=\"202\"></i>\n        </div>\n      </div>\n\n      <div class=\"bg-slate-900 border border-slate-800 rounded-[2rem] p-8 cursor-pointer hover:border-amber-400 transition-colors group\" data-kid=\"203\">\n        <div class=\"flex items-center justify-between\" data-kid=\"204\">\n          <h3 class=\"text-xl font-black text-white group-hover:text-amber-400 transition-colors\" data-kid=\"205\">Is the house price predictor really free to use?</h3>\n          <i data-lucide=\"plus\" class=\"w-6 h-6 text-slate-600 group-hover:text-amber-400 transition-colors\" data-kid=\"206\"></i>\n        </div>\n      </div>\n\n      <div class=\"bg-slate-900 border border-slate-800 rounded-[2rem] p-8 cursor-pointer hover:border-amber-400 transition-colors group\" data-kid=\"207\">\n        <div class=\"flex items-center justify-between\" data-kid=\"208\">\n          <h3 class=\"text-xl font-black text-white group-hover:text-amber-400 transition-colors\" data-kid=\"209\">What information do I need to get house price predictions?</h3>\n          <i data-lucide=\"plus\" class=\"w-6 h-6 text-slate-600 group-hover:text-amber-400 transition-colors\" data-kid=\"210\"></i>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"max-w-7xl mx-auto px-6 py-24\" data-kid=\"211\">\n    <div class=\"bg-slate-900 border-2 border-slate-800 rounded-[3.5rem] p-12 md:p-24 text-center relative overflow-hidden shadow-2xl\" data-kid=\"212\">\n      <div class=\"absolute -top-12 -right-12 opacity-[0.03]\" data-kid=\"213\">\n        <i data-lucide=\"home\" class=\"w-96 h-96 text-white\" data-kid=\"214\"></i>\n      </div>\n      <div class=\"relative z-10\" data-kid=\"215\">\n        <h2 class=\"text-4xl md:text-6xl font-black text-white mb-10 tracking-tight\" data-kid=\"216\">Ready to Discover Your <br class=\"hidden md:block\" data-kid=\"217\"> Property's Value?</h2>\n        <p class=\"text-slate-400 text-lg md:text-2xl mb-12 max-w-3xl mx-auto font-medium leading-relaxed\" data-kid=\"218\">\n   