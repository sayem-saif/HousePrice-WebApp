   </div>\n        \n        <div class=\"relative\" data-kid=\"90\">\n          <div class=\"relative bg-slate-950 rounded-[3rem] p-10 border-2 border-slate-800 shadow-2xl\" data-kid=\"91\">\n            <div class=\"flex items-start justify-between mb-10\" data-kid=\"92\">\n              <div data-kid=\"93\">\n                <span class=\"text-amber-400 text-xs font-black uppercase tracking-widest block mb-2\" data-kid=\"94\">Appraisal Board</span>\n                <h3 class=\"text-4xl font-black text-white\" data-kid=\"95\">Maple Heights</h3>\n              </div>\n              <div class=\"w-16 h-16 bg-slate-900 rounded-2xl border border-slate-800 flex items-center justify-center text-amber-400 shadow-inner\" data-kid=\"96\">\n                <i data-lucide=\"home\" class=\"w-8 h-8\" data-kid=\"97\"></i>\n              </div>\n            </div>\n            \n            <div class=\"bg-slate-950 rounded-[2rem] p-8 mb-8 border border-slate-800\" data-kid=\"98\">\n              <div class=\"flex items-center justify-between mb-2\" data-kid=\"99\">\n                <span class=\"text-slate-500 text-[10px] font-black uppercase tracking-widest\" data-kid=\"100\">Current Estimate</span>\n                <i data-lucide=\"maximize-2\" class=\"w-4 h-4 text-amber-400/50\" data-kid=\"101\"></i>\n              </div>\n              <div class=\"text-5xl font-black text-white mb-10 tracking-tight\" data-kid=\"102\">$284,760</div>\n              \n              <div class=\"grid grid-cols-3 gap-3\" data-kid=\"103\">\n                <div class=\"bg-slate-900/50 rounded-2xl p-5 border border-slate-800/50\" data-kid=\"104\">\n                  <i data-lucide=\"ruler\" class=\"w-5 h-5 text-amber-400 mb-4\" data-kid=\"105\"></i>\n                  <p class=\"text-[9px] font-black uppercase text-slate-500 mb-1 tracking-widest\" data-kid=\"106\">Area</p>\n                  <p class=\"text-xs font-black text-white\" data-kid=\"107\">2,140 sqft</p>\n                </div>\n      