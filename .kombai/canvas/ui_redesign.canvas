      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --accent: #facc15;\n    --navy-900: #0f172a;\n    --navy-800: #1e293b;\n    --navy-700: #334155;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--navy-900);\n    color: #f1f5f9;\n    margin: 0;\n  }\n\n  .font-heading {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n  }\n\n  .glow-yellow {\n    box-shadow: 0 0 20px rgba(250, 204, 21, 0.15);\n  }\n  \n  .glass-card {\n    background: rgba(30, 41, 59, 0.4);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(51, 65, 85, 0.5);\n  }\n\n  .accent-button {\n    background-color: var(--accent);\n    color: #0f172a;\n    transition: all 0.3s ease;\n  }\n\n  .accent-button:hover {\n    background-color: #fde047;\n    transform: translateY(-2px);\n    box-shadow: 0 10px 15px -3px rgba(250, 204, 21, 0.2);\n  }\n</style>\n\n<div class=\"bg-slate-900 selection:bg-yellow-400 selection:text-slate-950 min-h-[1000px]\" data-kid=\"1\">\n  \n  <nav class=\"relative z-50 flex items-center justify-between px-6 py-6 max-w-7xl mx-auto\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-10 h-10 bg-yellow-400 rounded-lg flex items-center justify-center\" data-kid=\"4\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#0f172a\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"5\"><path d=\"m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\" data-kid=\"6\"></path><polyline points=\"9 22 9 12 15 12 15 22\" data-kid=\"7\"></polyline></svg>\n      </div>\n      <span class=\"text-2xl font-black font-heading tracking-tight text-white\" data-kid=\"8\">Appraisal<span class=\"text-yellow-400\" data-kid=\"9\">Desk</span></span>\n    </div>\n    \n    <div class=\"hidden md:flex items-center gap-8\" data-kid=\"10\">\n      <a href=\"#\" class=\"text-sm font-semibold text-slate-300 hover:text-yellow-400 transition-colors\" data-kid=\"11\">Products</a>\n      <a href=\"#\" class=\"text-sm font-semibold text-slate-300 hover:text-yellow-400 transition-colors\" data-kid=\"12\">Solutions</a>\n      <a href=\"#\" class=\"text-sm font-semibold text-slate-300 hover:text-yellow-400 transition-colors\" data-kid=\"13\">Resources</a>\n      <a href=\"#\" class=\"text-sm font-semibold text-slate-300 hover:text-yellow-400 transition-colors\" data-kid=\"14\">About</a>\n    </div>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"15\">\n      <a href=\"#\" class=\"text-sm font-bold text-white hover:text-yellow-400 transition-colors\" data-kid=\"16\">Sign In</a>\n      <button class=\"accent-button px-5 py-2.5 rounded-lg font-bold text-sm\" data-kid=\"17\">Get Started</button>\n    </div>\n  </nav>\n\n  \n  <main data-kid=\"18\">\n    <section class=\"relative pt-12 pb-24 px-6 overflow-hidden\" data-kid=\"19\">\n      \n      <div class=\"absolute top-0 right-0 w-[500px] h-[500px] bg-yellow-400/5 blur-[120px] rounded-full -mr-64 -mt-32\" data-kid=\"20\"></div>\n      <div class=\"absolute bottom-0 left-0 w-[500px] h-[500px] bg-blue-500/5 blur-[120px] rounded-full -ml-64 -mb-32\" data-kid=\"21\"></div>\n\n      <div class=\"max-w-7xl mx-auto grid lg:grid-cols-[1.1fr_0.9fr] gap-16 items-center\" data-kid=\"22\">\n        \n        <div class=\"relative z-10 space-y-8\" data-kid=\"23\">\n          <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full border border-slate-800 bg-slate-800/50 text-slate-300 text-sm font-medium\" data-kid=\"24\">\n            <span class=\"flex h-2 w-2 rounded-full bg-yellow-400 animate-pulse\" data-kid=\"25\"></span>\n            Real-time Market Valuation Intelligence\n          </div>\n          <h1 class=\"text-5xl lg:text-7xl font-extrabold font-heading text-white leading-[1.1] tracking-tight\" data-kid=\"26\">\n            An appraisal desk for <span class=\"text-yellow-400\" data-kid=\"27\">instant</span> house prediction.\n          </h1>\n          <p class=\"text-xl text-slate-400 leading-relaxed max-w-xl\" data-kid=\"28\">\n            Enter the core property details and get a model-backed estimate in a focused workspace built for clarity, confidence, and quick iteration.\n          </p>\n          <div class=\"flex flex-col sm:flex-row gap-4\" data-kid=\"29\">\n            <button class=\"accent-button px-8 py-4 rounded-xl font-bold text-lg flex items-center justify-center gap-2 group shadow-xl border border-yellow-300\" data-kid=\"30\">\n              Open Prediction Desk\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"group-hover:translate-x-1 transition-transform\" data-kid=\"31\"><path d=\"M5 12h14\" data-kid=\"32\"></path><path d=\"m12 5 7 7-7 7\" data-kid=\"33\"></path></svg>\n            </button>\n            <button class=\"bg-slate-800 text-white border border-slate-700 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-700 hover:border-slate-600 transition-all flex items-center justify-center shadow-lg\" data-kid=\"34\">\n              View Sample Report\n            </button>\n          </div>\n          \n          \n          <div class=\"pt-8 border-t border-slate-800/60\" data-kid=\"35\">\n            <div class=\"grid grid-cols-3 gap-8\" data-kid=\"36\">\n              <div data-kid=\"37\">\n                <p class=\"text-white font-black text-2xl font-heading\" data-kid=\"38\">12M+</p>\n                <p class=\"text-slate-500 text-xs font-bold uppercase tracking-wider mt-1\" data-kid=\"39\">Properties Analyzed</p>\n              </div>\n              <div data-kid=\"40\">\n                <p class=\"text-white font-black text-2xl font-heading\" data-kid=\"41\">98.2%</p>\n                <p class=\"text-slate-500 text-xs font-bold uppercase tracking-wider mt-1\" data-kid=\"42\">Model Accuracy</p>\n              </div>\n              <div data-kid=\"43\">\n                <p class=\"text-white font-black text-2xl font-heading\" data-kid=\"44\">Instant</p>\n                <p class=\"text-slate-500 text-xs font-bold uppercase tracking-wider mt-1\" data-kid=\"45\">Report Delivery</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"relative group\" data-kid=\"46\">\n          \n          <div class=\"absolute -top-10 -right-6 z-30 bg-slate-950 border border-slate-700/50 px-4 py-2 rounded-full shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5)] flex items-center gap-2\" data-kid=\"47\">\n            <div class=\"w-2 h-2 rounded-full bg-yellow-400 animate-pulse\" data-kid=\"48\"></div>\n            <span class=\"text-[10px] font-black text-slate-200 uppercase tracking-widest\" data-kid=\"49\">Question 13 of 13</span>\n          </div>\n    \n          \n          <div class=\"absolute -top-6 -left-8 z-30 bg-slate-950 border border-slate-700/50 p-5 rounded-2xl shadow-[0_20px_50px_-12px_rgba(0,0,0,0.5)] transform group-hover:-translate-y-1 transition-transform duration-500\" data-kid=\"50\">\n            <div class=\"flex items-center gap-4\" data-kid=\"51\">\n              <div class=\"p-3 bg-yellow-400/10 rounded-xl\" data-kid=\"52\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#facc15\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"53\"><line x1=\"12\" x2=\"12\" y1=\"2\" y2=\"22\" data-kid=\"54\"></line><path d=\"M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6\" data-kid=\"55\"></path></svg>\n              </div>\n              <div data-kid=\"56\">\n                <p class=\"text-[10px] uppercase tracking-[0.15em] text-slate-500 font-black mb-0.5\" data-kid=\"57\">Live Valuation</p>\n                <p class=\"text-2xl font-black text-white font-heading tracking-tighter\" data-kid=\"58\">$284,760</p>\n              </div>\n            </div>\n          </div>\n    \n          \n          <div class=\"relative z-20 bg-slate-800/20 border border-slate-800 p-3 rounded-[2.5rem] shadow-2xl\" data-kid=\"59\">\n            <div class=\"bg-slate-950 rounded-[2.2rem] border border-slate-800/50 overflow-hidden shadow-inner\" data-kid=\"60\">\n              <div class=\"p-10\" data-kid=\"61\">\n                <div class=\"flex justify-between items-start mb-10\" data-kid=\"62\">\n                  <div data-kid=\"63\">\n                    <p class=\"text-yellow-400 text-[11px] font-black uppercase tracking-[0.25em] mb-2\" data-kid=\"64\">Wizard Active</p>\n                    <h3 class=\"text-3xl font-bold text-white font-heading\" data-kid=\"65\">Maple <span class=\"text-yellow-400 italic\" data-kid=\"66\">Heights</span></h3>\n                    <p class=\"text-slate-500 text-sm font-medium mt-1\" data-kid=\"67\">Single-family profile, modern baseline</p>\n                  </div>\n                  <div class=\"p-4 bg-slate-900 border border-slate-800 rounded-2xl text-yellow-400\" data-kid=\"68\">\n                     <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"69\"><path d=\"m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\" data-kid=\"70\"></path><polyline points=\"9 22 9 12 15 12 15 22\" data-kid=\"71\"></polyline></svg>\n                  </div>\n                </div>\n    \n                \n                <div class=\"bg-slate-900/80 border border-slate-800 rounded-3xl p-8 mb-8 relative\" data-kid=\"72\">\n                  \n                  <div class=\"absolute top-0 left-0 w-full h-1 bg-slate-800 rounded-t-3xl ov